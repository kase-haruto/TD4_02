#include "../Copy/CopyImage.hlsli"

///////////////////////////////////////////////////////////////////////////////
//                            structs
///////////////////////////////////////////////////////////////////////////////
struct CRTParam {
	float2 screenSize;
	float time;
};

///////////////////////////////////////////////////////////////////////////////
//                            cbuffers
///////////////////////////////////////////////////////////////////////////////
cbuffer CRTParam : register(b0) {
	CRTParam gCRTParam;
}

///////////////////////////////////////////////////////////////////////////////
//                            tables
///////////////////////////////////////////////////////////////////////////////
Texture2D<float4> gTexture : register(t0);

///////////////////////////////////////////////////////////////////////////////
//                            samplers
///////////////////////////////////////////////////////////////////////////////
SamplerState gSampler : register(s0);

///////////////////////////////////////////////////////////////////////////////
//                            functions
///////////////////////////////////////////////////////////////////////////////
float2 ApplyBarrelDistortion(float2 uv) {
	float2 coord = uv * 2.0f - 1.0f;
	float r2 = dot(coord, coord);
	coord *= 1.0f + 0.05f * r2 + 0.01f * r2 * r2; // より滑らかに
	return coord * 0.5f + 0.5f;
}

float CalcScanline(float2 uv) {
	float freq = 240.0f; // 線の密度
	float speed = 8.0f; // 動く速度
	return 0.9f + 0.1f * sin((uv.y * freq) + gCRTParam.time * speed);
}

///////////////////////////////////////////////////////////////////////////////
//                            main
///////////////////////////////////////////////////////////////////////////////
float4 main(VertexShaderOutput input) : SV_TARGET{
	// 歪み適用
	float2 distortedUV = ApplyBarrelDistortion(input.texcoord);

	// 元画像の色を取得
	float3 color = gTexture.Sample(gSampler, distortedUV).rgb;

	// 走査線効果を乗算
	color *= CalcScanline(distortedUV);

	return float4(color, 1.0f);
}
