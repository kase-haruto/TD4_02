///////////////////////////////////////////////////////////////////////////////
// structs
///////////////////////////////////////////////////////////////////////////////
struct VertexShaderInput {
	float4 position : POSITION0;
};

struct TransformationMat {
	float4x4 World;
	float4x4 WorldInverseTranspose;
};

///////////////////////////////////////////////////////////////////////////////
// tables
///////////////////////////////////////////////////////////////////////////////
StructuredBuffer<TransformationMat> gTransMat : register(t0);

///////////////////////////////////////////////////////////////////////////////
// cbuffers
///////////////////////////////////////////////////////////////////////////////
cbuffer ShadowCB : register(b0) {
	float4x4 gLightVP;
};

///////////////////////////////////////////////////////////////////////////////
// out
///////////////////////////////////////////////////////////////////////////////
struct VSOut {
	float4 svpos : SV_POSITION;
};

///////////////////////////////////////////////////////////////////////////////
// main
///////////////////////////////////////////////////////////////////////////////
VSOut main(VertexShaderInput input, uint instancedId : SV_InstanceID) {
	VSOut o;

	const TransformationMat tm = gTransMat[instancedId];

	float4 worldPos = mul(input.position, tm.World);

	o.svpos = mul(worldPos, gLightVP);

	return o;
}
